generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

enum TraitCategory {
  BACKGROUND
  BODY
  OUTFIT
  SHOES
  ACCESSORIES
  HAT
  EYES
  MOUTH
  SPECIAL
}

enum TraitRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum TraitAcquisition {
  MINT
  MARKETPLACE
  CRATE
  REWARD
}

enum AssetType {
  CUB
  TRAIT
  CRATE
}

model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique @map("wallet_address")
  role          Role     @default(USER)
  displayName   String?  @map("display_name")
  avatarUrl     String?  @map("avatar_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  cubs             Cub[]
  listings         MarketplaceListing[] @relation("SellerListings")
  purchases        MarketplaceListing[] @relation("BuyerListings")
  stakingPositions StakingPosition[]

  @@map("users")
}

model Cub {
  id          String   @id @default(cuid())
  tokenId     Int      @unique @map("token_id")
  name        String?
  description String?
  imageUrl    String?  @map("image_url")
  metadataUri String?  @map("metadata_uri")
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner    User                 @relation(fields: [ownerId], references: [id])
  traits   Trait[]
  listings MarketplaceListing[]
  staking  StakingPosition?

  @@map("cubs")
}

model Trait {
  id           String @id @default(cuid())
  cubId        String @map("cub_id")
  traitType    String @map("trait_type")
  traitValue   String @map("trait_value")
  displayOrder Int    @default(0) @map("display_order")

  cub Cub @relation(fields: [cubId], references: [id], onDelete: Cascade)

  @@unique([cubId, traitType])
  @@map("traits")
}

model MarketplaceListing {
  id                String        @id @default(cuid())
  assetType         AssetType     @map("asset_type")
  cubId             String?       @map("cub_id")
  traitDefinitionId String?       @map("trait_definition_id")
  crateDefinitionId String?       @map("crate_definition_id")
  quantity          Int           @default(1)
  sellerId          String        @map("seller_id")
  buyerId           String?       @map("buyer_id")
  priceWei          String        @map("price_wei")
  status            ListingStatus @default(ACTIVE)
  txHash            String?       @map("tx_hash")
  listedAt          DateTime      @default(now()) @map("listed_at")
  soldAt            DateTime?     @map("sold_at")
  cancelledAt       DateTime?     @map("cancelled_at")

  cub             Cub?             @relation(fields: [cubId], references: [id])
  traitDefinition TraitDefinition? @relation(fields: [traitDefinitionId], references: [id])
  crateDefinition CrateDefinition? @relation(fields: [crateDefinitionId], references: [id])
  seller          User             @relation("SellerListings", fields: [sellerId], references: [id])
  buyer           User?            @relation("BuyerListings", fields: [buyerId], references: [id])

  @@index([status, assetType])
  @@index([sellerId, status])
  @@map("marketplace_listings")
}

model MarketplaceSale {
  id             String   @id @default(cuid())
  listingId      String   @unique @map("listing_id")
  sellerId       String   @map("seller_id")
  buyerId        String   @map("buyer_id")
  priceWei       String   @map("price_wei")
  platformFeeWei String   @default("0") @map("platform_fee_wei")
  royaltyFeeWei  String   @default("0") @map("royalty_fee_wei")
  txHash         String?  @map("tx_hash")
  completedAt    DateTime @default(now()) @map("completed_at")

  @@index([sellerId])
  @@index([buyerId])
  @@map("marketplace_sales")
}

model TraitDefinition {
  id            String        @id @default(cuid())
  name          String
  category      TraitCategory
  rarity        TraitRarity
  maxSupply     Int           @map("max_supply")
  currentSupply Int           @default(0) @map("current_supply")
  imageUrl      String        @map("image_url")
  createdAt     DateTime      @default(now()) @map("created_at")

  userTraits UserTrait[]
  listings   MarketplaceListing[]

  @@unique([name, category])
  @@map("trait_definitions")
}

model UserTrait {
  id                String           @id @default(cuid())
  walletAddress     String           @map("wallet_address")
  traitDefinitionId String           @map("trait_definition_id")
  quantity          Int              @default(1)
  acquiredFrom      TraitAcquisition @map("acquired_from")
  acquiredAt        DateTime         @default(now()) @map("acquired_at")

  traitDefinition TraitDefinition @relation(fields: [traitDefinitionId], references: [id])

  @@unique([walletAddress, traitDefinitionId])
  @@map("user_traits")
}

model CrateDefinition {
  id          String      @id @default(cuid())
  name        String      @unique
  rarity      TraitRarity
  description String?
  imageUrl    String      @map("image_url")
  createdAt   DateTime    @default(now()) @map("created_at")

  userCrates UserCrate[]
  lootTable  LootTableEntry[]
  listings   MarketplaceListing[]

  @@map("crate_definitions")
}

model UserCrate {
  id                String          @id @default(cuid())
  walletAddress     String          @map("wallet_address")
  crateDefinitionId String          @map("crate_definition_id")
  quantity          Int             @default(1)
  acquiredAt        DateTime        @default(now()) @map("acquired_at")

  crateDefinition CrateDefinition @relation(fields: [crateDefinitionId], references: [id])

  @@unique([walletAddress, crateDefinitionId])
  @@map("user_crates")
}

model LootTableEntry {
  id                String          @id @default(cuid())
  crateDefinitionId String          @map("crate_definition_id")
  traitRarity       TraitRarity     @map("trait_rarity")
  probability       Float

  crateDefinition CrateDefinition @relation(fields: [crateDefinitionId], references: [id])

  @@unique([crateDefinitionId, traitRarity])
  @@map("loot_table_entries")
}

model StakingPosition {
  id             String    @id @default(cuid())
  cubId          String    @unique @map("cub_id")
  userId         String    @map("user_id")
  stakedAt       DateTime  @default(now()) @map("staked_at")
  unstakedAt     DateTime? @map("unstaked_at")
  rewardsClaimed String    @default("0") @map("rewards_claimed")
  txHash         String?   @map("tx_hash")
  isActive       Boolean   @default(true) @map("is_active")

  cub  Cub  @relation(fields: [cubId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("staking_positions")
}
